{% extends "home.html" %}
{% block css %}
  <link rel="stylesheet" type="text/css" href="/css/conciliacao/cadastroVeiculos.css" media="screen"/>
{% endblock %}
{% block principal %}
  <div class="veiculo-page">
    <div
      class="veiculo-card">
      <!-- Cabeçalho do card -->
      <div class="veiculo-card-header">
        <i class="bx bx-key"></i>
        <div>
          <h1>Retirada de Veículo</h1>
          <p>Registre os dados de saída e devolução do veículo.</p>
        </div>
      </div>
      <!-- Corpo do card -->
      <div class="veiculo-card-body">
        {% if mensagem %}
          <div style="background: {% if 'Erro' in mensagem %}#ffe5e5{% else %}#e6f9e6{% endif %}; color: {% if 'Erro' in mensagem
              %}#d1121d{% else %}#2d7a2d{% endif %}; padding: 12px 18px; border-radius: 8px; margin-bottom: 20px; font-size: 0.88rem;
              font-weight: 500;">
            {{ mensagem }}
          </div>
        {% endif %}
        <form method="POST" action="{{ BASE_URL }}/conciliacao/cadastro/retirada" id="form-cadastro-retirada">
          <div
            class="form-grid">
            <!-- Veículo -->
            <div class="field-group field-full">
              <label for="codigoVeiculo">Veículo
                <span class="required">*</span>
              </label>
              <div class="input-wrapper">
                <i class="bx bx-car"></i>
                <select id="codigoVeiculo" name="codigoVeiculo" required>
                  <option value="" disabled selected>Selecione o veículo utilizado</option>
                  {% for veiculo in veiculos %}
                    <option value="{{ veiculo.codigo }}">{{ veiculo.nome }} — {{ veiculo.placa }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>
            <!-- Data -->
            <div class="field-group">
              <label for="data">Data
                <span class="required">*</span>
              </label>
              <div class="input-wrapper">
                <i class="bx bx-calendar"></i>
                <input type="date" id="data" name="data" required/>
              </div>
            </div>
            <!-- KM Início -->
            <div class="field-group">
              <label for="kmInicio">KM Início</label>
              <div class="input-wrapper">
                <i class="bx bx-tachometer"></i>
                <input type="number" id="kmInicio" name="kmInicio" step="1" min="0" placeholder="0"/>
              </div>
            </div>
            <!-- KM Final -->
            <div class="field-group">
              <label for="kmFinal">KM Início</label>
              <div class="input-wrapper">
                <i class="bx bx-tachometer"></i>
                <input type="number" id="kmFinal" name="kmFinal" step="1" min="0" placeholder="0"/>
              </div>
            </div>
            <!-- Saída -->
            <div class="field-group">
              <label for="saida">Hora de Saída
                <span class="required">*</span>
              </label>
              <div class="input-wrapper">
                <i class="bx bx-log-out"></i>
                <input type="time" id="saida" name="saida" required/>
              </div>
            </div>
            <!-- Chegada -->
            <div class="field-group">
              <label for="chegada">Hora de Chegada
                <span class="required">*</span>
              </label>
              <div class="input-wrapper">
                <i class="bx bx-log-in"></i>
                <input type="time" id="chegada" name="chegada" required/>
              </div>
            </div>
          </div>
          <!-- /.form-grid -->
          <hr class="form-divider"/>
          <div class="form-actions">
            <button type="submit" class="btn-submit" id="btn-cadastrar-retirada">
              <i class="bx bx-save"></i>
              Cadastrar Retirada
            </button>
          </div>
        </form>
      </div>
      <!-- /.veiculo-card-body -->
    </div>
    <!-- /.veiculo-card -->
  </div>
  <!-- /.veiculo-page -->
{% endblock %}