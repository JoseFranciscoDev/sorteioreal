{% extends "home.html" %}

{% block css %}
<link rel="stylesheet" href="/css/navbar.css" media="screen" />
<link rel="stylesheet" type="text/css" href="/css/conciliacao/visualizar.css" media="screen" />
{% endblock %}

{% block principal %}
<div class="viz-page">
    <div class="viz-header">
        <i class="bx bx-list-ul"></i>
        <div>
            <h1>Dashboard Conciliação</h1>
            <p>Visualização de Visitas Técnicas e Veículos cadastrados.</p>
        </div>
    </div>

    <!-- Seção Veículos -->
    <div class="section-block">
        <div class="section-title">
            <i class="bx bx-car"></i> Veículos Cadastrados
        </div>
        <table class="viz-table">
            <thead>
                <tr>
                    <th>Placa</th>
                    <th>Modelo</th>
                    <th>Tipo</th>
                    <th>KM Atual</th>
                </tr>
            </thead>
            <tbody>
                {% for veiculo in veiculos %}
                <tr>
                    <td><strong>{{ veiculo.placa }}</strong></td>
                    <td>{{ veiculo.modelo }}</td>
                    <td>{{ veiculo.tipo }}</td>
                    <td>{{ veiculo.kmAtual }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" style="text-align: center; color: var(--text-muted);">Nenhum veículo cadastrado.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Seção Visitas -->
    <div class="section-block">
        <div class="section-title">
            <i class="bx bx-map-pin"></i> Visitas Técnicas Registradas
        </div>
        <table class="viz-table">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Cobrador</th>
                    <th>Veículo</th>
                    <th>Saída / Retorno</th>
                    <th>Corridas Realizadas</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for visita in visitas %}
                <tr>
                    <td>{{ visita.data }}</td>
                    <td><strong>{{ visita.cobrador }}</strong></td>
                    <td>{{ visita.veiculo }}</td>
                    <td>{{ visita.saida }} - {{ visita.retorno }}</td>
                    <td>{{ visita.totalCorridas }}</td>
                    <td>
                        <a href="{{ BASE_URL }}/conciliacao/visitas/{{ visita.id }}/corridas" class="btn-action">
                            <i class="bx bx-show"></i> Ver Corridas
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" style="text-align: center; color: var(--text-muted);">Nenhuma visita registrada.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
