{% extends "home.html" %}

{% block css %}
<link rel="stylesheet" href="/css/navbar.css" media="screen" />
<link rel="stylesheet" type="text/css" href="/css/conciliacao/visualizar.css" media="screen" />
{% endblock %}

{% block principal %}
<div class="viz-page">
    <div class="viz-header" style="justify-content: space-between;">
        <div style="display: flex; align-items: center; gap: 15px;">
            <i class="bx bx-briefcase-alt"></i>
            <div>
                <h1>Corridas da Visita #{{ visita.id }}</h1>
                <p>Data: {{ visita.data }} | Cobrador: {{ visita.cobrador }} | Veículo: {{ visita.veiculo }}</p>
            </div>
        </div>
        <a href="{{ BASE_URL }}/conciliacao/visualizar" class="btn-action" style="background: #999;">
            <i class="bx bx-arrow-back"></i> Voltar
        </a>
    </div>

    <!-- Lista de Corridas (Cards) -->
    <div class="section-block" style="background: transparent; box-shadow: none; padding: 0;">
        <div class="corridas-grid">
            {% for corrida in corridas %}
            <div class="corrida-card">
                <div class="corrida-card-header">
                    <span class="corrida-id">Reg: #{{ corrida.id }}</span>
                    <span class="corrida-horario"><i class="bx bx-time"></i> {{ corrida.horario }}</span>
                </div>
                
                <div class="corrida-cli"><i class="bx bx-user"></i> {{ corrida.cliente }}</div>
                <div class="corrida-end"><i class="bx bx-map"></i> {{ corrida.endereco }}</div>
                
                <div class="corrida-tags">
                    <span class="tag-simples"><i class="bx bx-target-lock"></i> Encontrado: 
                        <span class="{% if corrida.encontrado == 'Sim' %}badge badge-sim{% else %}badge badge-nao{% endif %}">
                            {{ corrida.encontrado }}
                        </span>
                    </span>
                    <span class="tag-simples"><i class="bx bx-handshake"></i> Renegociado: 
                        <span class="{% if corrida.renegociado == 'Sim' %}badge badge-sim{% else %}badge badge-nao{% endif %}">
                            {{ corrida.renegociado }}
                        </span>
                    </span>
                </div>

                <div class="corrida-footer">
                    <span>Pagamento: <span style="font-weight: 500; font-size: 0.85rem; color: var(--text-muted);">{{ corrida.pagou }}</span></span>
                    <span style="color: var(--primary);">R$ {{ corrida.valor }}</span>
                </div>
            </div>
            {% else %}
            <div style="grid-column: 1 / -1; text-align: center; color: var(--text-muted); padding: 40px; background: #fff; border-radius: 12px; border: 1px dashed var(--border);">
                <i class="bx bx-ghost" style="font-size: 3rem; margin-bottom: 10px;"></i>
                <p>Nenhuma corrida cadastrada para esta visita.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
