<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catalogo</title>
</head>
<body>
    {% for produto in produtos %}
    <div class="produto">
        <img src="{{produto.imagem}}" alt="{{produto.nome}}">
        <h2>{{produto.nome}}</h2>
        <p>{{produto.descricao}}</p>
        <p>{{produto.preco}}</p>
    </div>
    {% endfor %}
</body>
</html>