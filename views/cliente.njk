{% extends "index.html" %} 

{% block titulo %}
<title>Shopping Real - Cliente</title>
{% endblock %}

{% block css %}
<link rel="stylesheet" type="text/css" href="/css/cliente.css" media="screen" />
<link rel="icon" type="image/x-icon" href="/image/icon.png">
<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css"/>
{% endblock %}

{% block principal %}

    <nav>
      <div class="logo">
        <i class="bx bx-menu menu-icon"></i>
      </div>
      <div class="sidebar">
        <div class="logo">
          <i class="bx bx-menu menu-icon"></i>
        </div>
       <div class="sidebar-content">
            <ul class="lists">
              {% for item in links %}
              <li class="list">
                <a href="{{item.url}}" class="nav-link">
                  <i class="{{item.clase}}"></i>
                  <span class="link">{{item.nome}}</span>
                </a>
              </li>
             {% endfor %}
            </ul>

            <div class="bottom-cotent">
              {% for item2 in links2 %}
              <li class="list">
                <a href="{{item2.url}}" class="nav-link">
                  <i class="{{item2.clase}}"></i>
                  <span class="link">{{item2.nome}}</span>
                </a>
              </li>
              {% endfor %}
            </div>
          </div>
      </div>
    </nav>

    <section class="overlay"></section>

    <script>
        const navBar = document.querySelector("nav"),
        menuBtns = document.querySelectorAll(".menu-icon"),
        overlay = document.querySelector(".overlay");

        menuBtns.forEach((menuBtn) => {
        menuBtn.addEventListener("click", () => {
        navBar.classList.toggle("open");
        });
    });

        overlay.addEventListener("click", () => {
        navBar.classList.remove("open");
    });
    </script>

    <div class="Main-container">
        <div class="container-cliente">
            <div class="wrap-cliente">
                <span class="cliente-form-title">Cadastro de cliente</span>
                {% if erro %}
                   <p class="ms erro"><i class="icon icon-hand-paper-o"></i>{{erro}}</p>
                {% endif %}
                <form action="{{ url }}" method="POST">

                    <div class="wrap-input">
                        <input type="text" class="input-cliente" name="codigoVendedor" placeholder="Código do Vendedor" required>
                    </div>

                    <div class="wrap-input">
                        <input type="text" class="input-cliente" name="codigoCliente" placeholder="Código do Cliente" required>
                    </div>

                    <div class="wrap-input">
                        <input type="text" class="input-cliente" name="codigoPedido" placeholder="Código do Pedido">
                    </div>

                    <div class="btn-container">
                        <button type="submit" class="btn-cliente">Cadastrar</button>
                    </div>
                    
                </form>
            </div>
        </div>
    </div>
{% endblock %}