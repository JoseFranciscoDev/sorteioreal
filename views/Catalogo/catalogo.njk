{% extends "home.html" %}
{% block css %}
<link rel="stylesheet" type="text/css" href="/css/Catalogo/catalogo.css" />
<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css" />
{% endblock %}
{% block principal %}
<header class="cat-header">
    <div class="header-left ms-15">
        <h1>Catálogo de Produtos</h1>
    </div>
    <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Pesquisar produto...">
        <button type="button" onclick="filtrarProdutos()">
            <i class="bx bx-search"></i>
        </button>
    </div>
</header>
<div class="tabela-container">
    <table class="tabela-produtos" id="tabela-catalogo">
        <thead>
            <tr>
                <th>Código</th>
                <th>Produto</th>
                <th>Centro de lucro</th>
                <th>Imagens</th>
                {% if usuario and usuario.tipo == 'ADMIN' %}
                <th>Ações</th>
                {% endif %}
            </tr>
        </thead>
        <tbody>
            {% if produtos.length == 0 %}
            <tr>
                <td colspan="5" class="tabela-produtos__vazia">
                    <i class='bx bx-search-alt-2'></i>
                    <span>Nenhum produto encontrado.</span>
                </td>
            </tr>
            {% else %}
            {% for produto in produtos %}
            <tr class="tabela-produtos__linha">
                <td>{{ produto.codigo }}</td>
                <td class="tabela-produtos__descricao">{{ produto.nome if produto.nome else "Sem nome" }}</td>
                <td>
                    {{produto.grupo}}
                </td>
                <td>
                    {% if produto.temImagens %}
                    <a href="{{ baseUrl }}/produtos/{{ produto.codigo }}" class="btn-ver-tabela">Ver imagens</a>
                    {% else %}
                    <span class="badge-sem-imagem">Sem imagens</span>
                    {% endif %}
                </td>
                {% if usuario and usuario.tipo == 'ADMIN' %}
                <td>
                    <button class="btn-upload-modal" onclick="abrirModalUpload('{{ produto.codigo }}')">
                        <i class='bx bx-upload'></i>
                        Upload
                    </button>
                </td>
                {% endif %}
            </tr>
            {% endfor %}
            {% endif %}
        </tbody>
    </table>
</div>
<div class="pagination-bar">
    <a href="?pagina={{ paginaAtual - 1 }}" class="page-btn {% if paginaAtual <= 1 %}disabled{% endif %}">
        <i class="bx bx-chevron-left"></i>
        Anterior
    </a>
    <a href="?pagina={{ paginaAtual }}" class="page-num active">
        {{ paginaAtual }}
    </a>
    <a href="?pagina={{ paginaAtual + 1 }}" class="page-btn {% if paginaAtual >= totalPaginas %}disabled{% endif %}">
        Próxima
        <i class="bx bx-chevron-right"></i>
    </a>
</div>
<div id="modalUpload" class="modal-upload" style="display: none;">
    <div class="modal-upload-content">
        <span class="close-modal" onclick="fecharModalUpload()">&times;</span>
        <div class="wrap-cliente">
            <span class="cliente-form-title">Upload de Imagens</span>
            <div id="modal-upload-mensagem" style="display:none; margin-bottom: 10px; padding: 8px 12px; border-radius: 6px; font-size: 0.9rem;"></div>
            <form id="formUpload" enctype="multipart/form-data">
                <input type="hidden" name="codigo_produto" id="modal_codigo_produto" value="">
                <div class="wrap-input">
                    <input type="file" name="imagens" class="input-cliente file-input" multiple required
                        accept="image/*">
                </div>
                <div class="btn-container">
                    <button type="submit" class="btn-cliente" id="btn-enviar-imagens">Enviar Imagens</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    const BASE_URL = "{{ baseUrl }}";

    function filtrarProdutos() {
        const input = document.getElementById("searchInput");
        window.location.href = `${BASE_URL}/produtos?busca=${input.value}`;
    }
    document.getElementById("searchInput").addEventListener("keyup", function (e) {
        if (e.key === "Enter")
            filtrarProdutos();
    });

    document.addEventListener("DOMContentLoaded", function() {
        const urlParams = new URLSearchParams(window.location.search);
        const busca = urlParams.get('busca');
        if(busca) {
            document.getElementById("searchInput").value = busca;
        }
    });

    function abrirModalUpload(codigo) {
        document.getElementById('modal_codigo_produto').value = codigo;
        const msg = document.getElementById('modal-upload-mensagem');
        msg.style.display = 'none';
        msg.textContent = '';
        document.getElementById('btn-enviar-imagens').disabled = false;
        document.getElementById('modalUpload').style.display = 'flex';
    }

    function fecharModalUpload() {
        document.getElementById('modalUpload').style.display = 'none';
    }

    window.onclick = function (event) {
        const modal = document.getElementById('modalUpload');
        if (event.target == modal) {
            fecharModalUpload();
        }
    };

    document.getElementById('formUpload').addEventListener('submit', async function (e) {
        e.preventDefault();
        const btn = document.getElementById('btn-enviar-imagens');
        const msg = document.getElementById('modal-upload-mensagem');
        btn.disabled = true;
        btn.textContent = 'Enviando...';
        msg.style.display = 'none';

        const formData = new FormData(this);
        try {
            const resp = await fetch(`${BASE_URL}/uploads`, {
                method: 'POST',
                body: formData
            });
            const dados = await resp.json();

            if (resp.ok && dados.sucesso) {
                msg.style.background = '#d4edda';
                msg.style.color = '#155724';
                msg.style.border = '1px solid #c3e6cb';
                msg.textContent = dados.sucesso;
                msg.style.display = 'block';
                this.reset();
                setTimeout(() => {
                    fecharModalUpload();
                    window.location.reload();
                }, 1500);
            } else {
                msg.style.background = '#f8d7da';
                msg.style.color = '#721c24';
                msg.style.border = '1px solid #f5c6cb';
                msg.textContent = dados.erro || 'Erro ao enviar imagens.';
                msg.style.display = 'block';
                btn.disabled = false;
                btn.textContent = 'Enviar Imagens';
            }
        } catch (err) {
            msg.style.background = '#f8d7da';
            msg.style.color = '#721c24';
            msg.style.border = '1px solid #f5c6cb';
            msg.textContent = 'Erro de rede. Tente novamente.';
            msg.style.display = 'block';
            btn.disabled = false;
            btn.textContent = 'Enviar Imagens';
        }
    });
</script>
{% endblock %}