{% extends "home.html" %}

{% block css %}
<link rel="stylesheet" type="text/css" href="/css/clientes.css" media="screen" />
<link rel="icon" type="image/x-icon" href="/image/icon.png">
<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css"/>
<title>Shopping Real - Clientes</title>
{% endblock %}

{% block principal %}

    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Pedidos</h1>
        </div>

        <div class="table-container">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Cod. Pedido</th>
                        <th>Cod. Cliente</th>
                        <th>Código de Usuário</th>
                        <th>Data</th>
                        <th>Valor</th>
                        <th>Método de Pagamento</th>
                        <th>Quantidade de Cupons</th>
                        <th>Nome do cliente</th>
                        <th>CPF</th>
                        <th>Excluir</th>
                    </tr>
                </thead>
                <tbody>
                    {% if pedidos.length == 0 %}
                    <tr>
                        <td colspan="6" class="text-center">Nenhum pedido encontrado.</td>
                    </tr>
                    {% else %}
                    {% for pedido in pedidos %}
                    <tr>
                        <td>{{ pedido.codigo }}</td>
                        <td>{{ pedido.cliente }}</td>
                        <td>{{ pedido.usuario }}</td>
                        <td>{{ pedido.data }}</td>
                        <td>{{ pedido.valor }}</td>
                        <td>{{pedido.metodoPagamento}}</td>
                        <td>{{pedido.quantidade}}</td>
                        <td>{{pedido.nome}}</td>
                        <td>{{pedido.cpf}}</td>
                        <td><a href="{{url}}pedido/delete/{{pedido.codigo}}"><i class="bx bx-trash"></i></a></td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}
