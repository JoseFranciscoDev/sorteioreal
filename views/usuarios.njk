{% extends "index.html" %} 
{% block css %}
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="stylesheet" type="text/css" href="/css/home.css" media="screen" />
<link rel="stylesheet" type="text/css" href="/css/administracao.css" media="screen" />
<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css" />
<title>Gerir Usuários - Shopping Real</title>
{% endblock %} 

{% block principal %}
<nav>
  <div class="logo">
    <i class="bx bx-menu menu-icon"></i>
  </div>
  <div class="sidebar">
    <div class="logo">
      <i class="bx bx-menu menu-icon"></i>
    </div>
    <div class="sidebar-content">
      <ul class="lists">
        {% for item in links %}
        <li class="list">
          <a href="{{item.url}}" class="nav-link">
            <i class="{{item.clase}}"></i>
            <span class="link">{{item.nome}}</span>
          </a>
        </li>
        {% endfor %}
      </ul>
      <div class="bottom-cotent">
        {% for item2 in links2 %}
        <li class="list">
          <a href="{{item2.url}}" class="nav-link">
            <i class="{{item2.clase}}"></i>
            <span class="link">{{item2.nome}}</span>
          </a>
        </li>
        {% endfor %}
      </div>
    </div>
  </div>
</nav>

<section class="overlay"></section>

<div class="admin-container">
    <div class="admin-header">
        <h1 class="admin-title">Gestão de Usuários</h1>
        <a href="{{ url }}administracao/usuarios/criar" class="btn-primary">
            <i class='bx bx-plus'></i> Criar novo usuário
        </a>
    </div>

    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nome</th>
                    <th>Usuário</th>
                    <th>Email</th>
                    <th>Tipo</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for usuario in usuarios %}
                <tr>
                    <td>{{ usuario.codigo }}</td>
                    <td>{{ usuario.nome }}</td>
                    <td>{{ usuario.snome }}</td>
                    <td>{{ usuario.email }}</td>
                    <td>
                        {% if usuario.tipo == 1 %}
                            <span class="badge badge-admin">Administrador</span>
                        {% else %}
                            <span class="badge badge-user">Usuário</span>
                        {% endif %}
                    </td>
                    <td>
                        <button class="btn-action" title="Editar"><i class='bx bx-edit'></i></button>
                        <button class="btn-action btn-delete" title="Excluir"><i class='bx bx-trash'></i></button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">Nenhum usuário encontrado.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
  const navBar = document.querySelector("nav"),
    menuBtns = document.querySelectorAll(".menu-icon"),
    overlay = document.querySelector(".overlay");

  menuBtns.forEach((menuBtn) => {
    menuBtn.addEventListener("click", () => {
      navBar.classList.toggle("open");
    });
  });

  overlay.addEventListener("click", () => {
    navBar.classList.remove("open");
  });
</script>
{% endblock %}
