{% extends "home.html" %}
{% block css %}
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="stylesheet" type="text/css" href="/css/home.css" media="screen" />
<link rel="stylesheet" type="text/css" href="/css/administracao.css" media="screen" />
<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css" />
<title>Gerir Usuários - Shopping Real</title>
{% endblock %}

{% block principal %}
<div class="admin-container">
    <div class="admin-header">
        <h1 class="admin-title">Gestão de Usuários</h1>
        <a href="{{ BASE_URL }}/administracao/usuarios/criar" class="btn-primary">
            <i class='bx bx-plus'></i> Criar novo usuário
        </a>
    </div>

    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nome</th>
                    <th>Usuário</th>
                    <th>Email</th>
                    <th>Tipo</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for usuario in usuarios %}
                <tr>
                    <td>{{ usuario.codigo }}</td>
                    <td>{{ usuario.nome }}</td>
                    <td>{{ usuario.snome }}</td>
                    <td>{{ usuario.email }}</td>
                    <td>
                        {% if usuario.tipo == 'ADMIN' %}
                            <span class="badge badge-admin">Administrador</span>
                        {% elif usuario.tipo == 'NORMAL' %}
                            <span class="badge badge-user">Normal</span>
                        {% elif usuario.tipo == 'ADMIN_VEND' %}
                            <span class="badge badge-user">Admin Vendedor</span>
                        {% endif %}
                    </td>
                    <td>
                        <button class="btn-action" title="Editar"><i class='bx bx-edit'></i></button>
                        <button class="btn-action btn-delete" title="Excluir"><i class='bx bx-trash'></i></button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">Nenhum usuário encontrado.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
