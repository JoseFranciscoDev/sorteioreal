{% extends "index.html" %} 

{% block titulo %}
<title>Shopping Real - Clientes</title>
{% endblock %}

{% block css %}
<link rel="stylesheet" type="text/css" href="/css/clientes.css" media="screen" />
<link rel="icon" type="image/x-icon" href="/image/icon.png">
<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css"/>
{% endblock %}

{% block principal %}

    <nav>
      <div class="logo">
        <i class="bx bx-menu menu-icon"></i>
      </div>
      <div class="sidebar">
        <div class="logo">
          <i class="bx bx-menu menu-icon"></i>
        </div>
       <div class="sidebar-content">
            <ul class="lists">
              {% for item in links %}
              <li class="list">
                <a href="{{item.url}}" class="nav-link">
                  <i class="{{item.clase}}"></i>
                  <span class="link">{{item.nome}}</span>
                </a>
              </li>
             {% endfor %}
            </ul>

            <div class="bottom-cotent">
              <ul class="lists">
              {% for item2 in links2 %}
              <li class="list">
                <a href="{{item2.url}}" class="nav-link">
                  <i class="{{item2.clase}}"></i>
                  <span class="link">{{item2.nome}}</span>
                </a>
              </li>
              {% endfor %}
              </ul>
            </div>
          </div>
      </div>
    </nav>

    <div class="overlay"></div>

    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Clientes Cadastrados</h1>
            <a href="{{BASE_URL}}/cliente" class="btn-primary">
                <i class='bx bx-plus'></i> Novo Cliente
            </a>
        </div>

        <div class="table-container">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Código de Usuário</th>
                        <th>Cod. Vendedor</th>
                        <th>Cod. Cliente</th>
                        <th>Cod. Pedido</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    {% if clientes.length == 0 %}
                    <tr>
                        <td colspan="6" class="text-center">Nenhum cliente encontrado.</td>
                    </tr>
                    {% else %}
                    {% for cliente in clientes %}
                    <tr>
                        <td>{{ cliente.codigoUsuario }}</td>
                        <td>{{ cliente.codigoVendedor }}</td>
                        <td>{{ cliente.codigoCliente }}</td>
                        <td>{{ cliente.codigoPedido }}</td>
                        <td>{{ cliente.data }}</td>
                    </tr>
                    {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        const navBar = document.querySelector("nav"),
              menuBtns = document.querySelectorAll(".menu-icon"),
              overlay = document.querySelector(".overlay");

        menuBtns.forEach((menuBtn) => {
            menuBtn.addEventListener("click", () => {
                navBar.classList.toggle("open");
            });
        });

        overlay.addEventListener("click", () => {
            navBar.classList.remove("open");
        });
    </script>

{% endblock %}
